# Copia este archivo como .env y completa los valores

# Token del bot (BotFather → /mybots → API Token)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Supabase (mismo proyecto que la app React Native)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Opcional: restringe el bot a un único chat (tu chat_id)
# Obtén tu chat_id enviando cualquier mensaje al bot y revisando los logs
# ALLOWED_CHAT_ID=123456789
